# Calendry — environment variable reference
# Copy to .env.local and fill in real values.
# NEVER commit .env.local — it is gitignored.
# NEVER put real values in this file.

# ─── Public URL ────────────────────────────────────────────────────────────────
# Full https:// URL of your Calendry instance (no trailing slash)
NEXT_PUBLIC_URL=https://book.example.com

# ─── Supabase (self-hosted) ────────────────────────────────────────────────────
# Postgres connection string for the worker and migration tooling
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Supabase anon + service_role keys — generated by docker compose on first boot
# (printed to stdout; copy from there)
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret shared by GoTrue and PostgREST — generate with: openssl rand -base64 32
SUPABASE_JWT_SECRET=

# Supabase API URL (PostgREST gateway) — used by the web app
NEXT_PUBLIC_SUPABASE_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── GoTrue (admin auth) ───────────────────────────────────────────────────────
# Site URL used in magic-link emails — must match NEXT_PUBLIC_URL in production
GOTRUE_SITE_URL=https://book.example.com

# GoTrue master JWT secret — same value as SUPABASE_JWT_SECRET above
GOTRUE_JWT_SECRET=

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Create a project at https://console.cloud.google.com, enable Calendar API,
# create OAuth 2.0 credentials (Web application type).
# Authorized redirect URI: ${NEXT_PUBLIC_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Email ─────────────────────────────────────────────────────────────────────
# Resend API key — https://resend.com/api-keys (only required when EMAIL_DRIVER=resend)
RESEND_API_KEY=

# From address for transactional emails (must be a verified domain on Resend when using resend)
EMAIL_FROM=noreply@example.com

# Local-first default: `smtp` targets the Mailpit container in compose.
# For production deploy, swap to `resend` and set RESEND_API_KEY above.
EMAIL_DRIVER=smtp

# ─── SMTP (optional override; defaults point at the in-stack Mailpit) ─────────
# Leave unset in development — compose defaults route to mailpit:1025 (no auth needed).
# Set these only when targeting an external SMTP relay (e.g. production).
#SMTP_HOST=mailpit     # optional override; default: mailpit (in-stack)
#SMTP_PORT=1025        # optional override; default: 1025 (in-stack)
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=true

# ─── Security ──────────────────────────────────────────────────────────────────
# CSRF secret — generate with: openssl rand -base64 32
CSRF_SECRET=

# Signed cancel/reschedule link secret — generate with: openssl rand -base64 32
SIGNED_LINK_SECRET=

# ─── Rate limiting ─────────────────────────────────────────────────────────────
# Booking POST rate limit per IP (requests per minute)
RATE_LIMIT_PER_IP=10

# Booking POST rate limit per booker email (requests per minute)
RATE_LIMIT_PER_EMAIL=3

# ─── Supabase internal service secrets (docker compose) ───────────────────────
# Postgres password — used by docker-compose.yml
POSTGRES_PASSWORD=postgres

# DEV ONLY — GoTrue connects to Postgres as supabase_auth_admin.
# supabase/postgres:15.x creates this role with no password; ops/postgres-init/
# 00-supabase-roles.sql sets it to the value below on first container start.
# Production MUST override with a strong random password.
SUPABASE_AUTH_ADMIN_PASSWORD=auth_admin_pw_local

# DEV ONLY — PostgREST connects as authenticator.  Same caveat as above.
AUTHENTICATOR_PASSWORD=authenticator_pw_local

# DEV ONLY — Supabase Storage connects as supabase_storage_admin.
SUPABASE_STORAGE_ADMIN_PASSWORD=storage_admin_pw_local

# Supabase Studio dashboard password
STUDIO_DEFAULT_ORGANIZATION=Calendry
STUDIO_DEFAULT_PROJECT=calendry2

# Dashboard username/password for Supabase Studio
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=

# ─── Compose service ports (override defaults if ports conflict) ───────────────
WEB_PORT=3000
STUDIO_PORT=3002
GOTRUE_PORT=9999
POSTGREST_PORT=3001
REALTIME_PORT=4000
