# Calendry — environment variable reference
# Copy to .env.local and fill in real values.
# NEVER commit .env.local — it is gitignored.
# NEVER put real values in this file.

# ─── Public URL ────────────────────────────────────────────────────────────────
# Full https:// URL of your Calendry instance (no trailing slash)
NEXT_PUBLIC_URL=https://book.example.com

# ─── Supabase (self-hosted) ────────────────────────────────────────────────────
# Postgres connection string for the worker and migration tooling
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Supabase anon + service_role keys — generated by docker compose on first boot
# (printed to stdout; copy from there)
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret shared by GoTrue and PostgREST — generate with: openssl rand -base64 32
SUPABASE_JWT_SECRET=

# Supabase API URL (PostgREST gateway) — used by the web app
NEXT_PUBLIC_SUPABASE_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── GoTrue (admin auth) ───────────────────────────────────────────────────────
# Site URL used in magic-link emails — must match NEXT_PUBLIC_URL in production
GOTRUE_SITE_URL=https://book.example.com

# GoTrue master JWT secret — same value as SUPABASE_JWT_SECRET above
GOTRUE_JWT_SECRET=

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Create a project at https://console.cloud.google.com, enable Calendar API,
# create OAuth 2.0 credentials (Web application type).
# Authorized redirect URI: ${NEXT_PUBLIC_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# From address for transactional emails (must be a verified domain on Resend)
EMAIL_FROM=noreply@example.com

# Set to "smtp" to use generic SMTP relay instead of Resend
EMAIL_DRIVER=resend

# ─── SMTP fallback (only required when EMAIL_DRIVER=smtp) ─────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=true

# ─── Security ──────────────────────────────────────────────────────────────────
# CSRF secret — generate with: openssl rand -base64 32
CSRF_SECRET=

# Signed cancel/reschedule link secret — generate with: openssl rand -base64 32
SIGNED_LINK_SECRET=

# ─── Rate limiting ─────────────────────────────────────────────────────────────
# Booking POST rate limit per IP (requests per minute)
RATE_LIMIT_PER_IP=10

# Booking POST rate limit per booker email (requests per minute)
RATE_LIMIT_PER_EMAIL=3

# ─── Supabase internal service secrets (docker compose) ───────────────────────
# Postgres password — used by docker-compose.yml
POSTGRES_PASSWORD=postgres

# Supabase Studio dashboard password
STUDIO_DEFAULT_ORGANIZATION=Calendry
STUDIO_DEFAULT_PROJECT=calendry2

# Dashboard username/password for Supabase Studio
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=

# ─── Compose service ports (override defaults if ports conflict) ───────────────
WEB_PORT=3000
STUDIO_PORT=3002
GOTRUE_PORT=9999
POSTGREST_PORT=3001
REALTIME_PORT=4000
